# URL base do Azure DevOps (sem barra no final)
ADO_ORG_URL=https://tfs.suaempresa.com/Collection

# Nome do projeto no Azure DevOps (não a collection)
ADO_PROJECT=NomeDoProjeto

# Branch padrão de destino dos PRs
ADO_DEFAULT_TARGET_BRANCH=master

# Personal Access Token — permissão necessária: Code → Read & Write
ADO_PAT_TOKEN=seu-pat-token-aqui

# Repositório (opcional — detectado automaticamente pelo git remote)
# ADO_REPOSITORY=NomeDoRepositorio
